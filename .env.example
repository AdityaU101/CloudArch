# Required: PostgreSQL connection string
# Local example: postgresql://postgres:password@localhost:5432/cloud_arch_db
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/cloud_arch_db

# Required: Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: ports (defaults shown)
# PORT=3001          # API server port
# API_PORT=3001      # Used by frontend to proxy /api calls
